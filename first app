-- database/schema.sql

-- Extensions
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "pgcrypto";

-- ============================================
-- ARCHITECTS
-- ============================================
CREATE TABLE architects (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    name VARCHAR(255) NOT NULL,
    firm_name VARCHAR(255),
    license_number VARCHAR(100),
    phone VARCHAR(50),
    website VARCHAR(255),
    bio TEXT,
    specializations TEXT[] DEFAULT '{}',
    subscription_tier VARCHAR(50) DEFAULT 'free',
    stripe_customer_id VARCHAR(255),
    stripe_subscription_id VARCHAR(255),
    subscription_status VARCHAR(50) DEFAULT 'inactive',
    subscription_period_end TIMESTAMP,
    proposals_used_this_month INTEGER DEFAULT 0,
    usage_reset_date DATE DEFAULT DATE_TRUNC(
        'month', NOW() + INTERVAL '1 month'
    ),
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- FIRM BRANDING
-- ============================================
CREATE TABLE firm_branding (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    architect_id UUID REFERENCES architects(id) ON DELETE CASCADE,
    logo_url VARCHAR(500),
    primary_color VARCHAR(7) DEFAULT '#1a56db',
    secondary_color VARCHAR(7) DEFAULT '#374151',
    accent_color VARCHAR(7) DEFAULT '#f59e0b',
    font_heading VARCHAR(100) DEFAULT 'Inter',
    font_body VARCHAR(100) DEFAULT 'Inter',
    tagline VARCHAR(255),
    address TEXT,
    footer_text TEXT,
    email_signature TEXT,
    proposal_template VARCHAR(50) DEFAULT 'modern',
    updated_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- CLIENTS
-- ============================================
CREATE TABLE clients (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    architect_id UUID REFERENCES architects(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL,
    email VARCHAR(255),
    phone VARCHAR(50),
    company VARCHAR(255),
    address TEXT,
    city VARCHAR(100),
    country VARCHAR(100),
    notes TEXT,
    total_proposals INTEGER DEFAULT 0,
    created_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- PROPOSALS
-- ============================================
CREATE TABLE proposals (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    architect_id UUID REFERENCES architects(id) ON DELETE CASCADE,
    client_id UUID REFERENCES clients(id),
    team_id UUID,
    title VARCHAR(255) NOT NULL,
    project_type VARCHAR(100),
    status VARCHAR(50) DEFAULT 'draft',
    content JSONB NOT NULL DEFAULT '{}',
    raw_inputs JSONB DEFAULT '{}',
    budget_min DECIMAL(12,2),
    budget_max DECIMAL(12,2),
    timeline VARCHAR(255),
    valid_until DATE,
    public_token VARCHAR(255) UNIQUE DEFAULT encode(
        gen_random_bytes(32), 'hex'
    ),
    pdf_url VARCHAR(500),
    pdf_generated_at TIMESTAMP,
    view_count INTEGER DEFAULT 0,
    last_viewed_at TIMESTAMP,
    sent_at TIMESTAMP,
    accepted_at TIMESTAMP,
    rejected_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- TEAMS
-- ============================================
CREATE TABLE teams (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    owner_id UUID REFERENCES architects(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL,
    stripe_subscription_id VARCHAR(255),
    subscription_status VARCHAR(50) DEFAULT 'active',
    max_seats INTEGER DEFAULT 10,
    current_seats INTEGER DEFAULT 1,
    subscription_period_end TIMESTAMP,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE team_members (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    team_id UUID REFERENCES teams(id) ON DELETE CASCADE,
    architect_id UUID REFERENCES architects(id) ON DELETE CASCADE,
    role VARCHAR(50) DEFAULT 'member',
    status VARCHAR(50) DEFAULT 'pending',
    invited_email VARCHAR(255),
    invite_token VARCHAR(255) UNIQUE,
    invite_expires_at TIMESTAMP,
    joined_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT NOW(),
    UNIQUE(team_id, architect_id)
);

CREATE TABLE team_invites (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    team_id UUID REFERENCES teams(id) ON DELETE CASCADE,
    invited_by UUID REFERENCES architects(id),
    email VARCHAR(255) NOT NULL,
    role VARCHAR(50) DEFAULT 'member',
    token VARCHAR(255) UNIQUE NOT NULL,
    status VARCHAR(50) DEFAULT 'pending',
    expires_at TIMESTAMP DEFAULT NOW() + INTERVAL '7 days',
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE team_branding (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    team_id UUID REFERENCES teams(id) ON DELETE CASCADE,
    logo_url VARCHAR(500),
    primary_color VARCHAR(7) DEFAULT '#1a56db',
    secondary_color VARCHAR(7) DEFAULT '#374151',
    accent_color VARCHAR(7) DEFAULT '#f59e0b',
    font_heading VARCHAR(100) DEFAULT 'Inter',
    font_body VARCHAR(100) DEFAULT 'Inter',
    tagline VARCHAR(255),
    address TEXT,
    footer_text TEXT,
    updated_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- TEMPLATES
-- ============================================
CREATE TABLE proposal_templates (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    architect_id UUID REFERENCES architects(id) ON DELETE CASCADE,
    team_id UUID REFERENCES teams(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL,
    project_type VARCHAR(100),
    content JSONB DEFAULT '{}',
    is_default BOOLEAN DEFAULT false,
    is_locked BOOLEAN DEFAULT false,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- USAGE & BILLING
-- ============================================
CREATE TABLE usage_logs (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    architect_id UUID REFERENCES architects(id),
    team_id UUID REFERENCES teams(id),
    action VARCHAR(100),
    metadata JSONB DEFAULT '{}',
    billing_period VARCHAR(7),
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE billing_events (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    architect_id UUID REFERENCES architects(id),
    team_id UUID REFERENCES teams(id),
    stripe_event_id VARCHAR(255) UNIQUE,
    stripe_invoice_id VARCHAR(255),
    event_type VARCHAR(100),
    amount INTEGER,
    currency VARCHAR(10) DEFAULT 'usd',
    status VARCHAR(50),
    plan VARCHAR(50),
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- PROPOSAL EVENTS
-- ============================================
CREATE TABLE proposal_events (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    proposal_id UUID REFERENCES proposals(id) ON DELETE CASCADE,
    event_type VARCHAR(50),
    ip_address VARCHAR(45),
    user_agent TEXT,
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- INDEXES
-- ============================================
CREATE INDEX idx_proposals_architect ON proposals(architect_id);
CREATE INDEX idx_proposals_status ON proposals(status);
CREATE INDEX idx_proposals_token ON proposals(public_token);
CREATE INDEX idx_clients_architect ON clients(architect_id);
CREATE INDEX idx_branding_architect ON firm_branding(architect_id);
CREATE INDEX idx_team_members_team ON team_members(team_id);
CREATE INDEX idx_team_members_architect ON team_members(architect_id);
CREATE INDEX idx_usage_logs_architect ON usage_logs(architect_id);
CREATE INDEX idx_usage_logs_period ON usage_logs(billing_period);

-- ============================================
-- TRIGGERS
-- ============================================
CREATE OR REPLACE FUNCTION update_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER architects_updated_at
    BEFORE UPDATE ON architects
    FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER proposals_updated_at
    BEFORE UPDATE ON proposals
    FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER teams_updated_at
    BEFORE UPDATE ON teams
    FOR EACH ROW EXECUTE FUNCTION update_updated_at();
